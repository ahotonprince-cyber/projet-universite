# SERVER
PORT=5000
NODE_ENV=development
API_URL=http://localhost:5000

# DATABASE
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=cowec_microfinance
DB_POOL_LIMIT=10

# JWT
JWT_SECRET=your_super_secret_key_change_me
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_change_me
JWT_REFRESH_EXPIRES_IN=30d

# FRONTEND
FRONTEND_URL=http://localhost:5173

# EMAIL (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@cowec.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@cowec.com

# SMS (Twilio)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+221781234567

# ORANGE MONEY API
ORANGE_API_URL=https://api.orange.com/money/v1
ORANGE_CLIENT_ID=your_client_id
ORANGE_CLIENT_SECRET=your_client_secret
ORANGE_MERCHANT_ID=your_merchant_id

# MTN MONEY API
MTN_API_URL=https://sandbox.mtn.cm/mtn-momo
MTN_CLIENT_ID=your_client_id
MTN_CLIENT_SECRET=your_client_secret
MTN_API_KEY=your_api_key

# REDIS (optionnel)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# UPLOAD
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,application/pdf

# LOGGING
LOG_LEVEL=info
LOG_DIR=./logs