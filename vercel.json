{
  "buildCommand": "cd cowec-credit-app && npm install && npm run build",
  "outputDirectory": "cowec-credit-app/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://projet-universite-production.up.railway.app/api/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
